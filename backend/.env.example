# ProjectFlow Backend Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# --- Application ---
APP_ENV=development

# --- Database ---
DATABASE_URL=sqlite:///./data/projectflow.sqlite

# --- LLM Provider ---
# Provider mode: "mock" (offline/demo), "openai", or "openai-compatible"
LLM_PROVIDER=mock

# API key for OpenAI-compatible providers.
# Required when LLM_PROVIDER is "openai" or "openai-compatible".
# Leave empty for mock mode.
LLM_API_KEY=

# Base URL for the LLM API endpoint.
# Default: https://api.openai.com/v1
# Change for Azure OpenAI, local proxies, or other compatible endpoints.
LLM_BASE_URL=https://api.openai.com/v1

# Model identifier to use for completions.
# Examples: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# Request timeout in seconds for LLM API calls.
# Increase for slow endpoints or large prompts.
LLM_TIMEOUT_SECONDS=30.0
