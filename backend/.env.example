# ProjectFlow Backend Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# --- Application ---
APP_ENV=development

# --- Database ---
DATABASE_URL=sqlite:///./data/projectflow.sqlite

# --- LLM Provider ---
# Provider mode: "mock" (offline/demo), "openai", or "openai-compatible"
LLM_PROVIDER=mock

# API key for OpenAI-compatible providers.
# Required when LLM_PROVIDER is "openai" or "openai-compatible".
# Leave empty for mock mode.
LLM_API_KEY=

# Base URL for the LLM API endpoint.
# Default: https://api.openai.com/v1
# Change for Azure OpenAI, local proxies, or other compatible endpoints.
LLM_BASE_URL=https://api.modelarts-maas.com/v2/chat/completions

# Model identifier to use for completions.
# Examples: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=glm-5.1

# Request timeout in seconds for LLM API calls.
# Used by provider diagnostics and direct LLM client calls.
LLM_TIMEOUT_SECONDS=60.0

# Agent generation timeout in seconds.
# Structured planning runs are slower than health checks, so the default is higher.
LLM_AGENT_TIMEOUT_SECONDS=120.0

# --- Internal Service Token ---
# Shared secret between backend and agent-bridge sidecar.
# Required for T41 internal endpoints (/internal/agent-tools/*, /internal/agent-runs/*).
# Must match in both backend/.env and agent-bridge/.env.
INTERNAL_SERVICE_TOKEN=change-me
